# EasyCode 配置文件模板
# 复制为 easycode.yaml 并填入实际值

protocol: anthropic          # 协议: anthropic 或 openai
model: claude-sonnet-4-20250514  # 模型名称
base_url: https://api.anthropic.com  # API 地址
api_key: your-api-key-here   # API 密钥

# --- 以下为新字段（可选，省略则用默认值）---
# context_window: 128000     # 上下文窗口 token 上限
# tool_timeout: 30           # 工具执行超时秒数
# system_prompt: "你是一个有帮助的 AI 助手。"
